# Copy to secrets.yaml (the file is in .gitignore) and fill in the values.
# secrets.yaml is NEVER committed.

# Vulners API key (a paid plan is required for archive endpoints).
# Get one: https://docs.vulners.com/docs/quickstart/authentication/
vulners_api_key: "REPLACE_ME"

# Wi-Fi for the device (used by the firmware/config generator).
wifi_ssid: "REPLACE_ME"
wifi_password: "REPLACE_ME"

# Optional: password for OTA (over-the-air) firmware updates.
# If omitted, the build falls back to wifi_password.
ota_password: "REPLACE_ME"
